{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "Rosalution Annotation's Rendering Layout Schema",
  "description": "Schema for configuring the render layout of annotations in a Rosalution project with query by an analysis' genomic units",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "type": {
        "type": "string",
        "enum": [
          "section"
        ]
      },
      "class": { "$ref": "#/$defs/class" },
      "header": { "type": "string" },
      "anchor": { "type": "string" },
      "header_datasets": {
        "type": "array",
        "contains": {
          "type": "object",
          "properties": {
            "dataset": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "icon-linkout-dataset"
              ],
              "props": {
                "type": "object",
                "properties": {
                  "imageFilename": {
                    "type": "string"
                  },
                  "altText": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "rows": {
        "type": "array",
        "contains": {
          "type": "object",
          "properties": {
            "class": { "$ref": "#/$defs/class" },
            "datasets": {
              "type": "array",
              "contains": {
                "object":  { "$ref": "#/$defs/dataset" }
              }
            }
          }
        }
      }
    },
    "required": [
      "type",
      "header",
      "anchor",
      "rows"
    ],
    "$defs": {
      "class": {"type": "string"},
      "datasetComponentType": { 
        "type": "string",
        "enum": [
          "card-dataset",
          "clinvar-dataset",
          "icon-linkout-dataset",
          "images-dataset",
          "score-dataset",
          "set-dataset",
          "tag-dataset",
          "text-dataset",
          "transcript-datasets"

        ]
      },
      "dataset": {
        "type": "object",
        "properties": {
          "dataset": {"type": "string"},
          "genomicType": {
            "type": "string",
            "enum": [ "hgvs_variant", "gene" ]
          },
          "type": { "$ref": "#/$defs/datasetComponentType" }
        }
      }
    }
  },

  "minItems": 0
}